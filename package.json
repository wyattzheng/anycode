{
  "name": "any-code",
  "private": true,
  "scripts": {
    "dev:app": "pnpm --filter @any-code/app dev",
    "build:agent": "pnpm --filter @any-code/agent build",
    "build:server": "pnpm --filter @any-code/server build",
    "build": "pnpm -r build",
    "start": "pnpm --filter @any-code/agent build && pnpm --filter @any-code/app build && pnpm --filter @any-code/server build && pnpm --filter @any-code/server start"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["node-pty"]
  },
  "devDependencies": {
    "msw": "^2.12.10",
    "vitest": "^4.1.0"
  }
}
