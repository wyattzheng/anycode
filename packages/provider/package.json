{
    "name": "@any-code/provider",
    "version": "0.0.1",
    "type": "module",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./vendor-metadata": {
            "types": "./dist/vendor-metadata.d.ts",
            "import": "./dist/vendor-metadata.js",
            "require": "./dist/vendor-metadata.js",
            "default": "./dist/vendor-metadata.js"
        }
    },
    "files": ["dist"],
    "scripts": {
        "build": "tsup"
    },
    "dependencies": {
        "@any-code/utils": "workspace:*",
        "@ai-sdk/anthropic": "2.0.65",
        "@ai-sdk/google": "2.0.54",
        "@ai-sdk/openai": "2.0.89",
        "@ai-sdk/openai-compatible": "1.0.32",
        "@ai-sdk/provider": "2.0.1",
        "ai": "5.0.124",
        "effect": "4.0.0-beta.31",
        "fuzzysort": "3.1.0",
        "remeda": "2.26.0",
        "zod": "4.1.8"
    },
    "devDependencies": {
        "@types/node": "^25.5.0",
        "tsup": "^8.4.0",
        "typescript": "5.8.2"
    }
}
