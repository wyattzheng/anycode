{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "esModuleInterop": true,
        "strict": true,
        "strictNullChecks": false,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "lib": [
            "ESNext"
        ],
        "types": [
            "node"
        ],
        "paths": {
            "@/*": [
                "../opencode/src/*"
            ]
        }
    },
    "include": [
        "src",
        "tests",
        "dev.ts"
    ]
}